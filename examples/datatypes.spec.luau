--!strict
-- examples/datatypes.spec.luau — verifies datatype polyfills
describe("Vector3", function()
	it("constructs", function()
		local v = Vector3.new(1, 2, 3)
		expect(v.X).toBe(1)
		expect(v.Y).toBe(2)
		expect(v.Z).toBe(3)
	end)
	it("adds", function()
		local v = Vector3.new(1,1,1) + Vector3.new(2,2,2)
		expect(v.X).toBe(3)
		expect(v.Z).toBe(3)
	end)
	it("magnitude", function()
		expect(Vector3.new(3,4,0).Magnitude).toBe(5)
	end)
	it("zero/one constants", function()
		expect(Vector3.zero.X).toBe(0)
		expect(Vector3.one.Y).toBe(1)
	end)
end)

describe("UDim2", function()
	it("fromScale", function()
		local u = UDim2.fromScale(0.5, 1)
		expect(u.X.Scale).toBe(0.5)
		expect(u.Y.Scale).toBe(1)
	end)
end)

describe("Color3", function()
	it("fromRGB", function()
		local c = Color3.fromRGB(255, 0, 0)
		expect(c.R).toBe(1)
		expect(c.G).toBe(0)
	end)
end)
